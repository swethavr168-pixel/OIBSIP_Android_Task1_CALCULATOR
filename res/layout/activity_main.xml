<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#1E1A3E"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="10dp">

    <!-- HISTORY -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="80dp">

        <TextView
            android:id="@+id/historyView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#B0B0FF"
            android:textSize="14sp"
            android:gravity="end"
            android:padding="10dp"/>
    </ScrollView>

    <!-- DISPLAY -->
    <TextView
        android:id="@+id/display"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#2D2A5E"
        android:text="0"
        android:textSize="36sp"
        android:textColor="#FFFFFF"
        android:gravity="end|center_vertical"
        android:padding="20dp"
        android:maxLines="1"/>

    <!-- ROW 1 -->
    <LinearLayout style="@style/row">
        <Button style="@style/btn" android:id="@+id/btn7" android:text="7"/>
        <Button style="@style/btn" android:id="@+id/btn8" android:text="8"/>
        <Button style="@style/btn" android:id="@+id/btn9" android:text="9"/>
        <Button style="@style/btnOp" android:id="@+id/btnDivide" android:text="÷"/>
    </LinearLayout>

    <!-- ROW 2 -->
    <LinearLayout style="@style/row">
        <Button style="@style/btn" android:id="@+id/btn4" android:text="4"/>
        <Button style="@style/btn" android:id="@+id/btn5" android:text="5"/>
        <Button style="@style/btn" android:id="@+id/btn6" android:text="6"/>
        <Button style="@style/btnOp" android:id="@+id/btnMultiply" android:text="×"/>
    </LinearLayout>

    <!-- ROW 3 -->
    <LinearLayout style="@style/row">
        <Button style="@style/btn" android:id="@+id/btn1" android:text="1"/>
        <Button style="@style/btn" android:id="@+id/btn2" android:text="2"/>
        <Button style="@style/btn" android:id="@+id/btn3" android:text="3"/>
        <Button style="@style/btnOp" android:id="@+id/btnSubtract" android:text="-"/>
    </LinearLayout>

    <!-- ROW 4 (FIXED CLEAN) -->
    <LinearLayout style="@style/row">
        <Button style="@style/btnClear" android:id="@+id/btnClear" android:text="C"/>
        <Button style="@style/btn" android:id="@+id/btn0" android:text="0"/>
        <Button style="@style/btn" android:id="@+id/btnDot" android:text="."/>
        <Button style="@style/btnOp" android:id="@+id/btnAdd" android:text="+"/>
    </LinearLayout>

    <!-- ROW 5 -->
    <LinearLayout style="@style/row">
        <Button
            android:id="@+id/btnBack"
            style="@style/btn"
            android:layout_width="match_parent"
            android:text="⌫"/>
    </LinearLayout>

    <!-- EQUALS -->
    <LinearLayout style="@style/row">
        <Button
            android:id="@+id/btnEquals"
            style="@style/btn"
            android:layout_width="match_parent"
            android:text="="/>
    </LinearLayout>

</LinearLayout>